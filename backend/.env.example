# Токен бота Telegram (BotFather) — используется ТОЛЬКО для проверки подписи initData,
# нигде в код не хардкодить, файл .env не коммитить.
TELEGRAM_BOT_TOKEN=123456:AAAA-your-bot-token-here

# Домены, которым разрешено ходить в API (CORS). Через запятую, без пробелов.
ALLOWED_ORIGINS=https://hypergate-portal.vercel.app,http://localhost:5173

# Сколько секунд считать initData свежим (защита от replay-атак). 86400 = 24 часа.
INIT_DATA_MAX_AGE_SECONDS=86400

ENV=development

# Хранилище данных — Google Sheets (ПДн сотрудников не собираем и не храним,
# их держит внешний сервис Kleos; тут только tg_id/username/email/регион/статусы).
# ID таблицы — из её URL: docs.google.com/spreadsheets/d/<ЭТО>/edit
GOOGLE_SPREADSHEET_ID=1jGcpfwusaetXL4LYxzpTsM8udb1_t3BnUVBKNxCgsbE
GOOGLE_CREDENTIALS_PATH=credentials.json
# Альтернатива GOOGLE_CREDENTIALS_PATH — на хостингах без файловых секретов
# (напр. Replit) вставьте содержимое JSON-ключа целиком одной строкой сюда,
# GOOGLE_CREDENTIALS_PATH тогда можно не задавать вовсе.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}

# Белый список (кто может пользоваться порталом) — вкладка allowed_usernames
# в самой Google-таблице (см. scripts/setup_sheets.py), не переменная
# окружения — так его можно менять без пересборки бэкенда.

# ТОЛЬКО для локальной демонстрации без Telegram (см. app/auth/dependencies.py).
# По умолчанию должно ОТСУТСТВОВАТЬ/быть false — включать только на своей машине.
# ALLOW_DEV_AUTH_BYPASS=true
